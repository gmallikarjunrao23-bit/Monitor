model MaintenanceWindow {
  id          String   @id @default(cuid())
  monitorId   String
  title       String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())

  @@index([monitorId])
  @@map("maintenance_windows")
}

model OnCallSchedule {
  id        String   @id @default(cuid())
  userId    String
  teamId    String?
  name      String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("on_call_schedules")
}
